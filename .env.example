# ── Clerk ──────────────────────────────────────────────────────────────────────
# Get both keys from: https://dashboard.clerk.com → your project → API Keys

# Publishable key — safe to embed in HTML (it's public-facing)
# Paste this into the Clerk initialisation call in your HTML files
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret key — NEVER put in frontend code or commit a real value
# Set it in Cloudflare via: npx wrangler secret put CLERK_SECRET_KEY
# Development value starts with:  sk_test_
# Production value starts with:   sk_live_
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
